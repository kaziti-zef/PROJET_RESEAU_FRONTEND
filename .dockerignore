# ============================================================
#  NidiRoom — .dockerignore
#  Fichiers exclus du contexte de build Docker
#  (réduit la taille de l'image et accélère le build)
# ============================================================

# Dépendances (reconstruites dans le container)
node_modules
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Build Next.js (reconstruit dans le container)
.next
out

# Environnement local (ne jamais embarquer dans Docker)
.env
.env.local
.env.development.local
.env.test.local
.env.production.local

# Git
.git
.gitignore
.gitattributes

# IDE et éditeurs
.vscode
.idea
*.swp
*.swo

# OS
.DS_Store
Thumbs.db

# Tests
coverage
.nyc_output
__tests__
*.test.ts
*.test.tsx
*.spec.ts
*.spec.tsx

# Documentation
README.md
CHANGELOG.md
docs

# Docker (pas besoin de s'inclure lui-même)
Dockerfile
.dockerignore
docker-compose.yml
docker-compose*.yml
